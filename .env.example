# Microsoft Graph App registration (Azure AD)
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_TENANT=common

# monday.com OAuth app
MONDAY_CLIENT_ID=
MONDAY_CLIENT_SECRET=
MONDAY_SIGNING_SECRET=

# 32 random bytes, base64 — encrypts token columns
TOKEN_ENC_KEY=

# Supabase project
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Public origin used in OAuth redirect URIs (optional — falls back to VERCEL_URL on Vercel, then localhost:3000)
APP_BASE_URL=https://localhost:3000

# monday board to sync (items with dates become Outlook calendar events)
MONDAY_BOARD_ID=
